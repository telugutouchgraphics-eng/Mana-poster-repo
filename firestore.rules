rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Direct client access to subscription entitlements is read-only for owner.
    // Writes must go through trusted backend (Cloud Functions with Admin SDK).
    match /users/{userId}/entitlements/{entitlementId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    // Optional purchase event view: owner can read own events only.
    match /users/{userId}/purchaseEvents/{eventId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if false;
    }

    // User-owned poster profile sync for app-side profile persistence.
    match /users/{userId}/posterProfile/{profileId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User-owned device FCM tokens for push notification delivery.
    match /users/{userId}/deviceTokens/{tokenId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // App-open token capture before login to send welcome push.
    match /publicDeviceTokens/{tokenId} {
      allow create, update: if
        request.resource.data.token is string &&
        request.resource.data.token.size() > 40 &&
        request.resource.data.platform in ["android", "ios", "other"];
      allow read, delete: if false;
    }

    // Free feed can read only manager-approved creator posters.
    match /creatorPosters/{posterId} {
      allow read: if resource.data.status == "approved";
      allow create, update, delete: if false;
    }

    // Public app banners for home/category promotional surfaces.
    match /appBanners/{bannerId} {
      allow read: if resource.data.active == true;
      allow create, update, delete: if false;
    }

    // Block all other direct access by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
